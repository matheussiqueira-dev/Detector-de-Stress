# StressCam — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste conforme necessário.
# Nenhuma variável é obrigatória; os defaults estão definidos em stresscam/config.py.

# ── Câmera ────────────────────────────────────────────────────────────────
# STRESSCAM_DEVICE_INDEX=0          # Índice OpenCV da câmera (padrão: 0)
# STRESSCAM_DEVICE=BRIO 305         # Nome DirectShow da câmera (Windows)
# STRESSCAM_FPS=30                  # Taxa de captura desejada

# ── Servidor API ──────────────────────────────────────────────────────────
# STRESSCAM_HTTP_PORT=8000          # Porta REST (GET /score, /health, /history)
# STRESSCAM_WS_PORT=8765            # Porta WebSocket
# STRESSCAM_ENABLE_SERVER=true      # Habilitar servidor (true/false)

# ── Modelo ────────────────────────────────────────────────────────────────
# STRESSCAM_MODEL_TYPE=sgd          # "sgd" ou "rf" (Random Forest)
# STRESSCAM_AUTO_SAVE_MODEL=true    # Salvar modelo após treino do baseline

# ── Gravação de sessão ────────────────────────────────────────────────────
# STRESSCAM_ENABLE_RECORDING=true   # Gravar histórico em JSON/CSV ao encerrar

# ── Baseline ──────────────────────────────────────────────────────────────
# STRESSCAM_BASELINE_SEC=15         # Duração da calibração inicial (segundos)
# STRESSCAM_HIGH_SENSITIVITY=true   # Modo de alta sensibilidade (demo)

# ── Logging ───────────────────────────────────────────────────────────────
# STRESSCAM_LOG_LEVEL=INFO          # debug / info / warning / error / critical

# ── Frontend (Next.js) ────────────────────────────────────────────────────
# NEXT_PUBLIC_STRESSCAM_API_URL=http://localhost:8000
# NEXT_PUBLIC_STRESSCAM_WS_URL=ws://localhost:8765
